import json

class CUSMemoryManager:
    def __init__(self, max_short_term=5):
        # Mantém apenas as últimas X mensagens na tela (imede travamentos)
        self.short_term_buffer = deque(maxlen=max_short_term)
        # Simula o banco vetorial de longo prazo (onde os embeddings seriam salvos)
        self.long_term_vector_db = []

    def adicionar_mensagem(self, papel, texto):
        """Adiciona mensagem na conversa ativa e gerencia o expurgo."""
        mensagem = {"role": papel, "content": texto}
        
        # Se o buffer estiver cheio, a mensagem mais antiga 'cai' e vai para a memória longa
        if len(self.short_term_buffer) == self.short_term_buffer.maxlen:
            mensagem_expurgada = self.short_term_buffer[0]
            self.enviar_para_banco_vetorial(mensagem_expurgada)
            
        self.short_term_buffer.append(mensagem)

    def enviar_para_banco_vetorial(self, mensagem):
        """Simula a transformação do texto antigo em vetor matemático."""
        print(f"🔄 [CUS-Memory] Convertendo para vetor e salvando na nuvem: '{mensagem['content'][:30]}...'")
        self.long_term_vector_db.append(mensagem)

    def cordao_umbilical_extrair_metadados(self):
        """O Cordão (IA Neuropsicológica) analisa as mensagens locais e gera o JSON para a MOM."""
        # Exemplo ultra simples de análise de sentimento local por palavras-chave
        texto_completo = " ".join([m["content"].lower() for m in self.short_term_buffer if m["role"] == "user"])
        
        nivel_ansiedade = 1
        if "travei" in texto_completo or "desesperado" in texto_completo:
            nivel_ansiedade = 9
        elif "difícil" in texto_completo or "cansado" in texto_completo:
            nivel_ansiedade = 5

        # JSON limpo e anônimo que vai para a MOM
        payload_mom = {
            "usuario_id_anonimo": "Feto_Cognitivo_8472",
            "metadados_neuropsicologicos": {
                "nivel_ansiedade_detectado": nivel_ansiedade,
                "alerta_evasao": True if nivel_ansiedade > 7 else False,
                "interacao_ativa": len(self.short_term_buffer)
            }
        }
        return json.dumps(payload_mom, indent=4, ensure_ascii=False)

